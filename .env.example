# ── Application ───────────────────────────────────────────
APP_ENV=development                              # development | staging | production
APP_SECRET_KEY=change-this-to-a-random-64-char-string  # Application-level secret
APP_HOST=0.0.0.0                                 # Bind host
APP_PORT=8000                                    # Bind port
DEBUG=true                                       # Enable debug mode

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-64-char-string  # JWT signing secret
JWT_ALGORITHM=HS256                              # JWT algorithm
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15               # Access token TTL in minutes
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30                 # Refresh token TTL in days

# ── MySQL ─────────────────────────────────────────────────
MYSQL_HOST=mysql                                 # MySQL service hostname
MYSQL_PORT=3306                                  # MySQL port
MYSQL_DATABASE=trustflow                         # Database name
MYSQL_USER=trustflow_user                        # Database user
MYSQL_PASSWORD=change-this-password              # Database user password
MYSQL_ROOT_PASSWORD=change-this-root-password    # MySQL root password
DATABASE_URL=mysql+aiomysql://trustflow_user:change-this-password@mysql:3306/trustflow  # Full async DB URL

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis                                 # Redis service hostname
REDIS_PORT=6379                                  # Redis port
REDIS_URL=redis://redis:6379/0                   # Redis URL for general use
CELERY_BROKER_URL=redis://redis:6379/0           # Celery broker (Redis DB0)
CELERY_RESULT_BACKEND=redis://redis:6379/1       # Celery result backend (Redis DB1)
CACHE_REDIS_DB=2                                 # Application cache (Redis DB2)

# ── MinIO (Local S3-compatible storage) ───────────────────
MINIO_ENDPOINT=http://minio:9000                 # MinIO API endpoint (used as boto3 endpoint_url)
MINIO_ACCESS_KEY=minioadmin                      # MinIO access key
MINIO_SECRET_KEY=minioadmin                      # MinIO secret key
MINIO_BUCKET=trustflow-receipts                  # Default bucket for receipt storage
MINIO_USE_SSL=false                              # Use SSL for MinIO connections

# ── Currency API (ExchangeRate API) ───────────────────────
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key-here  # API key for exchangerate-api.com
EXCHANGE_RATE_BASE_URL=https://api.exchangerate-api.com/v4/latest  # Base URL for exchange rate lookups

# ── RestCountries (no key needed) ─────────────────────────
COUNTRIES_API_URL=https://restcountries.com/v3.1/all?fields=name,currencies  # Public countries API

# ── GSTIN API ─────────────────────────────────────────────
GSTIN_API_KEY=your-gstin-api-key-here            # API key for apisetu.gov.in GSTN service
GSTIN_API_BASE_URL=https://apisetu.gov.in/gstn/v3/taxpayers  # GSTIN verification base URL
GSTIN_VERIFY_THRESHOLD=5000                      # Amount threshold (INR) for API verification vs regex-only

# ── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here  # Google Maps API key (Geocoding + Places)
GOOGLE_MAPS_GEOCODE_URL=https://maps.googleapis.com/maps/api/geocode/json  # Geocoding API URL
GOOGLE_MAPS_PLACES_URL=https://maps.googleapis.com/maps/api/place/nearbysearch/json  # Nearby Search API URL
GPS_MISMATCH_THRESHOLD_METERS=500                # Haversine distance threshold for GPS mismatch flagging

# ── SendGrid ──────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key-here      # SendGrid email API key
SENDGRID_FROM_EMAIL=noreply@trustflow.in         # From address for all outbound emails
SENDGRID_FROM_NAME=TrustFlow                     # From display name

# ── Tesseract OCR (local — no external API key) ───────────
TESSERACT_CMD=/usr/bin/tesseract                 # Path to Tesseract binary inside Docker

# ── Celery ────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2                      # Number of concurrent Celery worker processes
CELERY_TASK_MAX_RETRIES=3                        # Default max retries for Celery tasks

# ── Security ──────────────────────────────────────────────
WITNESS_SECRET=change-this-to-a-random-secret-for-hmac  # HMAC secret for witness confirmation tokens
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # Comma-separated allowed CORS origins

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_LOGIN=5/15minute                      # Login endpoint: 5 attempts per 15 minutes per IP+email
RATE_LIMIT_SIGNUP=3/hour                         # Signup endpoint: 3 attempts per hour per IP
RATE_LIMIT_EXPENSE_CREATE=20/hour                # Expense creation: 20 per hour per user_id
